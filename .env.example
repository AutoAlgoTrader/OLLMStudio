# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── LM Studio connection ───────────────────────────────────────────────────────

# URL of the LM Studio server.
# Use http://localhost:1234/ for local, or a remote address for a network host.
LMS_BASE_URL=http://localhost:1234/

# API key for LM Studio's authentication (if enabled).
# In LM Studio: Settings → Server → API Keys → create a key and paste it here.
# Leave empty or unset if auth is disabled.
LMS_API_KEY=

# ── Proxy bind settings ────────────────────────────────────────────────────────

# Address and port the proxy listens on (standard Ollama port).
# PROXY_HOST=0.0.0.0
# PROXY_PORT=11434

# ── Timeouts (seconds) ────────────────────────────────────────────────────────

# PROXY_REQUEST_TIMEOUT=300.0
# PROXY_CONNECT_TIMEOUT=5.0

# ── Compatibility ──────────────────────────────────────────────────────────────

# Ollama version string reported to clients.
# OLLAMA_VERSION=0.6.4
